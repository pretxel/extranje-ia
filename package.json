    "@clerk/nextjs": "^6.0.0",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.4.3",
    "@langchain/textsplitters": "^1.0.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "ai": "^6.0.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "langchain": "^1.3.1",
    "next": "^16.2.2",
    "node-cron": "^3.0.3",
    "openai": "^6.0.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
