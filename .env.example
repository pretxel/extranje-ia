# Database
# Single-DB dev: set DATABASE_URL only (DIRECT_URL falls back to it).
# Supabase: DATABASE_URL = pooled (pgBouncer, port 6543); DIRECT_URL = direct (port 5432).
#   Runtime/queries use DATABASE_URL; Prisma migrations + ingestion use DIRECT_URL.
#   On the pooled URL append the Prisma pgBouncer flags, e.g. ?pgbouncer=true&connection_limit=1
#   (verify exact flags against current Prisma + Supabase docs before use).
DATABASE_URL=postgresql://user:password@localhost:5432/extranjeraia
# DIRECT_URL=postgresql://user:password@localhost:5432/extranjeraia

# Auth (Supabase) — both are public. Get from Supabase Dashboard → Project → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Login methods: Google OAuth (needs a Google Cloud OAuth client in Supabase) + magic link.
# Add the app origin(s) to Supabase Auth → URL Configuration → Redirect URLs: <origin>/auth/callback

# Embedding provider: "openai" (default) | "google"
# NOTE: switching embedding providers requires dropping and recreating the rag_vectors
# table — OpenAI ada-002 is 1536-dim, Google embedding-001 is 768-dim.
AI_EMBEDDING_PROVIDER=openai

# Optional model overrides
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Agent chat (OpenAI-locked, ignores AI_*_PROVIDER)
AGENT_CHAT_ENABLED=false
# OPENAI_AGENT_MODEL=gpt-4o
# OPENAI_AGENT_EMBEDDING_MODEL=text-embedding-3-small

# Required when OpenAI used for chat or embeddings
OPENAI_API_KEY=

# Required when Google used for embeddings
GOOGLE_GENERATIVE_AI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EMPRESA=price_...

# Paid plans availability. Unset/false → paid CTAs show "Próximamente" (coming soon)
# and /api/checkout returns 503. Set BOTH to "true" together to enable live checkout.
# NEXT_PUBLIC_* is inlined at build time, so flipping these requires a redeploy.
PAID_PLANS_ENABLED=
NEXT_PUBLIC_PAID_PLANS_ENABLED=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics (GA4 measurement ID, e.g. G-XXXXXXXXXX) — public, optional.
# Analytics load only when set; leave blank to disable.
NEXT_PUBLIC_GA_ID=
