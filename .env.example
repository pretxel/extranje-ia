DATABASE_URL=postgresql://user:password@localhost:5432/extranjeraia

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Chat provider: "openai" (default) | "anthropic" | "google"
AI_CHAT_PROVIDER=openai

# Embedding provider: "openai" (default) | "google"
# NOTE: switching embedding providers requires dropping and recreating the rag_vectors
# table — OpenAI ada-002 is 1536-dim, Google embedding-001 is 768-dim.
AI_EMBEDDING_PROVIDER=openai

# Optional model overrides
# OPENAI_CHAT_MODEL=gpt-4o
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
# GOOGLE_CHAT_MODEL=gemini-2.0-flash
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Required when OpenAI used for chat or embeddings
OPENAI_API_KEY=

# Required when AI_CHAT_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required when Google used for chat or embeddings
GOOGLE_GENERATIVE_AI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EMPRESA=price_...

NEXT_PUBLIC_APP_URL=http://localhost:3000
